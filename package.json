{
  "name": "church-crm",
  "version": "1.0.0",
  "description": "Multi-tenant Church Management SaaS CRM",
  "private": true,
  "workspaces": ["backend", "frontend"],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "install:all": "npm install && npm install --workspace=backend && npm install --workspace=frontend",
    "migrate": "npm run migrate --workspace=backend",
    "seed": "npm run seed --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
